
admin_variables =
{
    # Allow passing admin password via variable, default to 'admin'
    admin_credentials = "admin:{{ proxysql_admin_password | default('admin') }}"

    # 0.0.0.0 is usually required for containerized environments if you want to access
    # the admin interface from outside the specific container namespace,
    # though 127.0.0.1 works if using strictly host networking and local access only.
    mysql_ifaces      = "{{ proxysql_admin_interface | default('127.0.0.1:6032') }}"
}

mysql_variables =
{
    threads                           = 4
    max_connections                   = 2048
    default_query_delay               = 0
    default_query_timeout             = 36000000
    have_compress                     = true
    poll_timeout                      = 2000

    # Listen on port 3308 as requested
    interfaces                        = "0.0.0.0:{{ proxysql_mysql_port | default('3308') }}"

    # Error handling
    mysql_query_retries_on_mismatch   = 1

    # Monitor credentials
    monitor_username                  = "maxscale_monitor"
    monitor_password                  = "{{ mysql_maxscale_monitor_password }}"

    # Monitor interval (Galera Healthchecks)
    monitor_galera_healthcheck_interval = 2000
    monitor_galera_healthcheck_timeout  = 1000
}

mysql_servers =
(
    # Logic adapted to match MaxScale template:
    # 1. Defaults to using the 'database_servers' group.
    # 2. Looks up 'private_ip' in hostvars for each host (like your MaxScale config).
    # 3. Allows manual override via 'proxysql_backend_nodes' list if needed.
{% set db_hosts = proxysql_backend_nodes | default(groups['database_servers'] | sort) %}
{% for host in db_hosts %}
    {% set db_ip = hostvars[host]['private_ip'] if (host in hostvars and 'private_ip' in hostvars[host]) else host %}
    # Node {{ loop.index }} ({{ host }} -> {{ db_ip }})
    { address="{{ db_ip }}", port=3306, hostgroup=10, max_connections=200, use_ssl=1 },
    { address="{{ db_ip }}", port=3306, hostgroup=20, max_connections=200, use_ssl=1 }{{ "," if not loop.last else "" }}
{% endfor %}
)

# Galera Cluster Logic
mysql_galera_hostgroups =
(
    {
        writer_hostgroup        = 10
        backup_writer_hostgroup = 20
        reader_hostgroup        = 20
        offline_hostgroup       = 9000
        active                  = 1
        allow_primary_reads     = 1
        writer_is_also_reader   = 1
        max_writers             = 1
    }
)

mysql_users =
(
    {
        username          = "maxscale"
        password          = "{{ mysql_maxscale_password }}"
        default_hostgroup = 10
        active            = 1
    },
    {
        # Reusing the variables from your backend template for consistency
        username          = "{{ teamwire_db_user | default('teamwire') }}"
        password          = "{{ teamwire_db_password }}"
        default_hostgroup = 10
        active            = 1
    }
)

# Read/Write Splitting Rules
mysql_query_rules =
(
    # Rule 100: Send 'SELECT ... FOR UPDATE' to Writer (HG10)
    {
        rule_id               = 100
        active                = 1
        match_pattern         = "^SELECT.*FOR UPDATE$"
        destination_hostgroup = 10
        apply                 = 1
    },

    # Rule 200: Send standard 'SELECT' to Readers (HG20)
    {
        rule_id               = 200
        active                = 1
        match_pattern         = "^SELECT"
        destination_hostgroup = 20
        apply                 = 1
    }

    # Implicit default: Everything else goes to user's default_hostgroup (10)
)
