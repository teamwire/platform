# description: listen on 127.0.0.1:25 and forward incoming connections to nullmailer

service nullmailer
{
    # Set default options for the service
    user        = mail
    group       = mail
    type        = UNLISTED
    socket_type	= stream
    wait        = no

    # Configure the bind protocol, ip and port
    protocol    = tcp
    bind        = 127.0.0.1
    port        = 25

    # Limit the allowed ips to connect to the service
    only_from   = 127.0.0.1

    # program to execute for this service
    server      = /usr/bin/nullmailer-smtpd
}

{% if enable_monitoring is defined and enable_monitoring | lower in [ "yes", "true" ] and ( groups['all'] | length() == 1 or inventory_hostname in groups['management_servers'] ) -%}
service nullmailer-for-monitoring
{
    # Set default options for the service
    user        = mail
    group       = mail
    type        = UNLISTED
    socket_type	= stream
    wait        = no

    # Configure the bind protocol, ip and port
    protocol    = tcp
    bind        = 127.0.1.1
    port        = 25

    # Limit the allowed ips to connect to the service
    only_from   = 127.0.0.1

    # program to execute for this service
    server      = /usr/bin/nullmailer-smtpd
}

{% endif %}
